# Example environment variables for SpareSense.
#
# Copy to `.env` and fill in values as needed.

# Nessie (required for Nessie-backed endpoints in backend/app/main.py)
NESSIE_API_KEY=""
# Optional: Nessie request timeout (seconds)
NESSIE_TIMEOUT_S=10

# Gemini (optional for demo if you use precomputed outputs)
GEMINI_API_KEY=""

# Optional tuning
# GEMINI_MODEL=models/gemini-2.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_TIMEOUT_S=20
# GEMINI_TEMPERATURE=0.2
# GEMINI_MAX_OUTPUT_TOKENS=2048
# GEMINI_MAX_RETRIES=1
# GEMINI_MAX_RETRY_SLEEP_S=10
# GEMINI_CACHE_TTL_S=600

# Hackathon demo mode (recommended)
# Serve precomputed AI outputs for the seeded demo user.
AI_USE_PRECOMPUTED=1
AI_DEMO_USER_ID=alex_demo
# AI_PRECOMPUTED_DIR=backend/app/ai/precomputed

# Solana (optional - transfers require a keypair file)
# SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_MAIN_KEYPAIR_PATH=/absolute/path/to/wallet-keypair.json
